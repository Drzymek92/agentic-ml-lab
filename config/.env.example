# agentic_ml_lab — environment variables (copy to config/.env and fill real values; .env is gitignored)

# --- Kaggle API (https://www.kaggle.com/settings -> Create New Token) ---
# Either set these two, or place kaggle.json at ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- FuelIX LLM gateway (agentic loops) — see skills/llm_connection.md for the canonical list ---
FUELIX_API_KEY=
FUELIX_BASE_URL=
FUELIX_MODEL=

# --- Reproducibility ---
GLOBAL_SEED=42
